# ── Groq (required) ──────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Database (required) ───────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./memorymeet.db

# ── CORS (required) ───────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Hindsight Memory ──────────────────────────────────────────────────────────
# How Hindsight authentication works:
#
# Option A — Self-hosted local (NO API key needed):
#   Run: docker run -p 8888:8888 \
#          -e HINDSIGHT_API_LLM_API_KEY=your_groq_key \
#          -e HINDSIGHT_API_LLM_PROVIDER=groq \
#          ghcr.io/vectorize-io/hindsight:latest
#   HINDSIGHT_BASE_URL=http://localhost:8888
#   HINDSIGHT_API_KEY=                        ← leave blank, no auth needed
#
# Option B — Hindsight Cloud (API key = bearer token for your cloud instance):
#   Sign up: https://ui.hindsight.vectorize.io
#   HINDSIGHT_BASE_URL=https://your-cloud-endpoint-url
#   HINDSIGHT_API_KEY=your-cloud-api-key      ← from your Hindsight dashboard
#
# Option C — Leave both blank → app uses built-in SQLite memory (no Hindsight)
#
HINDSIGHT_BASE_URL=
HINDSIGHT_API_KEY=
